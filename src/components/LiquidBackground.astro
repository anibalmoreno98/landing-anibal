<div class="background-gradient"></div>

<style>
.background-gradient {
  position: fixed;
  inset: 0;
  width: 100vw;
  height: 100vh;
  z-index: -1;
  background: linear-gradient(to bottom, #ffffff 0%, #fafbfc 40%, #f5f7fb 100%);
  pointer-events: none;
}

/* Grid sutil de fondo */
.background-gradient::before {
  content: "";
  position: absolute;
  inset: 0;
  background-image: 
    linear-gradient(90deg, rgba(37, 99, 235, 0.03) 1px, transparent 1px),
    linear-gradient(rgba(37, 99, 235, 0.03) 1px, transparent 1px);
  background-size: 40px 40px;
  background-position: 0 0, 0 0;
  opacity: 0.5;
  pointer-events: none;
}

/* Glow sutil en las esquinas */
.background-gradient::after {
  content: "";
  position: absolute;
  inset: 0;
  background-image: 
    radial-gradient(ellipse at 20% 30%, rgba(37, 99, 235, 0.08) 0%, transparent 40%),
    radial-gradient(ellipse at 80% 70%, rgba(124, 58, 237, 0.08) 0%, transparent 40%),
    radial-gradient(ellipse at 40% 100%, rgba(6, 182, 212, 0.06) 0%, transparent 35%);
  pointer-events: none;
}
</style>
